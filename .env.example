# ──────────────────────────────────────────
# MongoDB
# ──────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/logx_express

# ──────────────────────────────────────────
# Redis
# ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────
# JWT
# ──────────────────────────────────────────
JWT_SECRET=your_jwt_secret_must_be_at_least_32_characters_long
JWT_REFRESH_SECRET=your_refresh_secret_must_be_at_least_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ──────────────────────────────────────────
# AWS S3
# ──────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1
AWS_BUCKET=logx-express-storage

# ──────────────────────────────────────────
# Google Maps
# ──────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ──────────────────────────────────────────
# WhatsApp (choose provider: zapi | twilio)
# ──────────────────────────────────────────
WHATSAPP_PROVIDER=zapi

# Z-API
ZAPI_INSTANCE_ID=your_instance_id
ZAPI_TOKEN=your_token

# Twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ──────────────────────────────────────────
# App
# ──────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ──────────────────────────────────────────
# Seed (first run only — change immediately)
# ──────────────────────────────────────────
SEED_SUPER_ADMIN_EMAIL=admin@example.com
SEED_SUPER_ADMIN_PASSWORD=admin123

# ──────────────────────────────────────────
# Mobile driver app (apps/mobile/.env)
# Copy to apps/mobile/.env — see apps/mobile/BUILD_ANDROID.md
# ──────────────────────────────────────────
# EXPO_PUBLIC_API_URL=http://10.0.2.2:4000
# EXPO_PUBLIC_API_URL=http://192.168.1.100:4000
