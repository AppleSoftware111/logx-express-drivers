{
  "name": "logx-express",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build --filter=@logx/api... --filter=@logx/web...",
    "dev": "turbo run dev",
    "lint": "turbo run lint --filter=@logx/api... --filter=@logx/web... --filter=@logx/mobile",
    "lint:fix": "turbo run lint:fix --filter=@logx/api... --filter=@logx/web...",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .prettierignore",
    "type-check": "turbo run type-check --filter=@logx/api... --filter=@logx/web... --filter=@logx/mobile",
    "test:i18n": "npm run test --workspace=@logx/i18n",
    "verify": "npm run test:i18n && npm run lint && npm run type-check && npm run build",
    "clean": "turbo run clean"
  },
  "overrides": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.5.0"
}
