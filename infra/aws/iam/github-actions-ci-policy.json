{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "EcrReadWriteSpecificRepos",
      "Effect": "Allow",
      "Action": [
        "ecr:BatchCheckLayerAvailability",
        "ecr:BatchGetImage",
        "ecr:CompleteLayerUpload",
        "ecr:DescribeImages",
        "ecr:DescribeRepositories",
        "ecr:GetAuthorizationToken",
        "ecr:GetDownloadUrlForLayer",
        "ecr:InitiateLayerUpload",
        "ecr:ListImages",
        "ecr:PutImage",
        "ecr:UploadLayerPart"
      ],
      "Resource": [
        "arn:aws:ecr:sa-east-1:123456789012:repository/logx-api",
        "arn:aws:ecr:sa-east-1:123456789012:repository/logx-web"
      ]
    },
    {
      "Sid": "EcsDeploySpecificServices",
      "Effect": "Allow",
      "Action": [
        "ecs:DescribeServices",
        "ecs:DescribeTaskDefinition",
        "ecs:RegisterTaskDefinition",
        "ecs:UpdateService",
        "ecs:ListTasks",
        "ecs:DescribeTasks"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:RequestedRegion": "sa-east-1"
        }
      }
    },
    {
      "Sid": "PassOnlyEcsExecutionRoles",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": [
        "arn:aws:iam::123456789012:role/logx-ecs-task-execution-role",
        "arn:aws:iam::123456789012:role/logx-ecs-task-role"
      ]
    },
    {
      "Sid": "CloudFrontInvalidationSingleDistribution",
      "Effect": "Allow",
      "Action": [
        "cloudfront:CreateInvalidation",
        "cloudfront:GetInvalidation"
      ],
      "Resource": "arn:aws:cloudfront::123456789012:distribution/ECN1RSCDU3H3U"
    },
    {
      "Sid": "AppBucketScopedAccess",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::my-website-bucket"
    },
    {
      "Sid": "AppBucketObjectsScopedAccess",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::my-website-bucket/*"
    }
  ]
}
