    "@react-navigation/native-stack": "^6.11.0",
    "@tanstack/react-query": "^5.51.1",
    "axios": "^1.7.2",
    "date-fns": "^3.6.0",
    "expo": "~51.0.0",
    "expo-camera": "~15.0.0",
    "expo-constants": "~16.0.0",
    "expo-file-system": "~17.0.0",
    "expo-font": "~12.0.0",
    "expo-location": "~17.0.0",
    "expo-secure-store": "~13.0.0",
    "expo-splash-screen": "~0.27.0",
    "expo-status-bar": "~1.12.0",
