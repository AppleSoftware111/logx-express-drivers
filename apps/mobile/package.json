    "build:aab:cloud": "eas build --platform android --profile production",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "expo clean"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@logx/shared": "*",
    "@react-navigation/bottom-tabs": "^6.6.1",
